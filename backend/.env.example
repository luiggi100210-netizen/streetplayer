# ============================================================
# STREETPLAYER — Variables de entorno Backend
# ============================================================

# Servidor
PORT=4000
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/streetplayer

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo
JWT_EXPIRES_IN=7d

# CORS — separar con comas sin espacios
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Admin inicial — correr: node src/db/seed.js
ADMIN_PASSWORD=cambia_esto_por_una_password_segura

# Cloudinary (fotos de perfil y eventos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps (geocoding)
GOOGLE_MAPS_API_KEY=

# Zona horaria
TZ=America/Lima
